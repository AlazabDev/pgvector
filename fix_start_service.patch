المشكلة: is-active --quiet postgresql كان بيرجع 'active' (target عام) حتى لو
الكتلة الجديدة تحديدًا (17/main على المنفذ المخصص) مش شغالة فعليًا، فالسكريبت
كان بيكمل لخطوة CREATE EXTENSION قبل ما الـsocket يكون موجود أصلاً.

مُختبَر: أعدت إنتاج فشل systemctl is-active في بيئة container بدون systemd
حقيقي (نفس نمط مشكلة WSL السابقة)، وأكدت إن pg_ctlcluster + فحص وجود
/var/run/postgresql/.s.PGSQL.$PORT بيشتغل بشكل موثوق بدونه.
---
 setup_postgres_az.sh | 29 ++++++++++++++++++++++++-----
 1 file changed, 24 insertions(+), 5 deletions(-)

diff --git a/setup_postgres_az.sh b/setup_postgres_az.sh
index 3551c88..1b8f6f3 100644
--- a/setup_postgres_az.sh
+++ b/setup_postgres_az.sh
@@ -337,11 +337,30 @@ EOF
 # ================================================================
 start_service() {
     step "تشغيل خدمة PostgreSQL $PG_VER"
-    # على Debian/Ubuntu
-    systemctl restart postgresql || true
-    sleep 3
-    systemctl is-active --quiet postgresql || error "خدمة PostgreSQL لا تعمل"
-    success "خدمة PostgreSQL قيد التشغيل"
+
+    # ملاحظة مهمة: "systemctl restart postgresql" بيشتغل على target عام بيغطي
+    # كل الكتل المسجّلة، وممكن يرجّع "active" حتى لو الكتلة الجديدة تحديدًا
+    # (بالمنفذ المخصص) مش شغالة فعليًا — خصوصًا على حاويات/أنظمة systemd فيها
+    # مش شغال بالكامل كـPID 1 (شفنا نفس النمط في مشكلة WSL قبل كده). الحل
+    # الأضمن: pg_ctlcluster مباشرة (أداة Debian الأصلية، بتشتغل بدون أي اعتماد
+    # على systemd)، مع انتظار فعلي لظهور socket الاتصال بدل sleep ثابت أعمى.
+    if command -v pg_ctlcluster >/dev/null 2>&1; then
+        pg_ctlcluster $PG_VER $PG_CLUSTER restart 2>&1 || pg_ctlcluster $PG_VER $PG_CLUSTER start || true
+    else
+        systemctl restart postgresql || true
+    fi
+
+    local socket_path="/var/run/postgresql/.s.PGSQL.$PG_PORT"
+    local waited=0
+    until [[ -S "$socket_path" ]] || [[ $waited -ge 30 ]]; do
+        sleep 1
+        waited=$((waited + 1))
+    done
+
+    if [[ ! -S "$socket_path" ]]; then
+        error "خدمة PostgreSQL لا تستجيب على المنفذ $PG_PORT (الـsocket $socket_path غير موجود بعد ${waited} ثانية) — راجع: pg_lsclusters و tail $PG_LOG"
+    fi
+    success "خدمة PostgreSQL قيد التشغيل فعليًا على المنفذ $PG_PORT (تم التحقق من الـsocket)"
 }
 
